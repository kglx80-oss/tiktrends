{%- comment -%} 360labs — Split texte + média (réutilisable) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Split' }}">
  <div class="wrap split reveal{% if section.settings.media_position == 'left' %} media-left{% endif %}" style="{% if section.settings.media_position == 'left' %}direction:rtl{% endif %}">
    <div class="split-txt" style="direction:ltr">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
      {%- endif -%}
    </div>
    <figure class="figure media-well" style="direction:ltr">
      <div class="ph {{ section.settings.ratio }}">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | default: section.settings.heading | strip_html }}" loading="lazy">
        {%- else -%}
          <span>{{ section.settings.placeholder }}</span>
        {%- endif -%}
      </div>
      {%- if section.settings.caption != blank -%}<span class="media-tag">{{ section.settings.caption }}</span>{%- endif -%}
    </figure>
  </div>
</section>

{% schema %}
{
  "name": "360labs · Split",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "select", "id": "media_position", "label": "Position du média", "options": [ { "value": "right", "label": "Droite" }, { "value": "left", "label": "Gauche" } ], "default": "right" },
    { "type": "header", "content": "Texte" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La thèse" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Trop de marques meurent d'un seul levier manquant." },
    { "type": "richtext", "id": "text", "label": "Paragraphes", "default": "<p>Un beau site sans trafic. Du trafic qui ne convertit pas. Des ventes sans rentabilité. La plupart des marques ne manquent pas d'ambition — elles manquent d'un <strong>système complet</strong>.</p><p>Depuis 2019, on a construit l'inverse d'une agence mono-levier : un groupe qui couvre toute la chaîne, et qui <strong>construit, possède et scale ses propres marques</strong> avant de mettre cette machine au service de la vôtre.</p>" },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Comprendre le Groupe" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-soft", "label": "Discret" }, { "value": "btn-glass", "label": "Iridescent" } ], "default": "btn-soft" },
    { "type": "header", "content": "Média" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "ratio", "label": "Format", "options": [ { "value": "tall", "label": "Portrait 3/4" }, { "value": "", "label": "Paysage 4/3" }, { "value": "wide", "label": "Large 16/9" }, { "value": "sq", "label": "Carré 1/1" } ], "default": "tall" },
    { "type": "text", "id": "placeholder", "label": "Texte du placeholder", "default": "espace photo — l'équipe au travail / studio" },
    { "type": "text", "id": "caption", "label": "Légende", "default": "espace photo · 3/4" }
  ],
  "presets": [ { "name": "360labs · Split" } ]
}
{% endschema %}
