{%- comment -%}
  360labs — Footer
  Marque + tagline + réseaux sociaux + colonnes de liens (blocs basés sur des menus).
{%- endcomment -%}

<footer class="labs foot">
  <div class="wrap foot-grid">
    <div class="foot-brand">
      <div class="nav-brand" style="gap:11px">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ section.settings.brand_text | strip_html }}" style="height:40px;width:auto">
        {%- else -%}
          <span class="mark mark-40"><svg viewBox="0 0 40 40" fill="none"><g stroke="rgba(26,20,48,.5)" stroke-width="1.4"><circle cx="20" cy="20" r="13"></circle><path d="M7 20h26M20 7c4 4 4 22 0 26M20 7c-4 4-4 22 0 26M9.5 13h21M9.5 27h21"></path></g></svg></span>
        {%- endif -%}
        <span class="wordmark" style="font-size:22px;color:#F4F4F8">{{ section.settings.brand_text }}</span>
      </div>
      {%- if section.settings.tagline != blank -%}<p class="foot-base">{{ section.settings.tagline }}</p>{%- endif -%}
      <div class="foot-soc">
        {%- if section.settings.linkedin != blank -%}<a href="{{ section.settings.linkedin }}" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"></rect><path d="M7 10v7M7 7v.01M11 17v-4a2 2 0 0 1 4 0v4M11 13v4"></path></svg></a>{%- endif -%}
        {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><path d="M17 7v.01"></path></svg></a>{%- endif -%}
        {%- if section.settings.tiktok != blank -%}<a href="{{ section.settings.tiktok }}" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M14 4v9.5a4 4 0 1 1-3-3.87M14 4c0 2.5 2 4.5 5 4.5"></path></svg></a>{%- endif -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      <div class="foot-col" {{ block.shopify_attributes }}>
        <h4>{{ block.settings.heading }}</h4>
        {%- if block.settings.menu != blank -%}
          {%- for link in block.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="wrap foot-bot">
    <span>{{ section.settings.copyright }}</span>
    <span>{{ section.settings.signature }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "360labs · Footer",
  "tag": "section",
  "class": "labs-section labs-footer-section",
  "settings": [
    { "type": "header", "content": "Marque" },
    { "type": "text", "id": "brand_text", "label": "Texte du logo (HTML)", "default": "360<b>labs</b>" },
    { "type": "image_picker", "id": "logo", "label": "Logo image (optionnel)" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "L'écosystème qui construit, possède et propulse les marques e-commerce. Depuis 2019." },
    { "type": "header", "content": "Réseaux sociaux" },
    { "type": "url", "id": "linkedin", "label": "LinkedIn" },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "tiktok", "label": "TikTok" },
    { "type": "header", "content": "Bas de page" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 360LABS — Tous droits réservés." },
    { "type": "text", "id": "signature", "label": "Signature", "default": "Iridescent · Sora" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Colonne de liens",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre de colonne", "default": "Le Groupe" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Footer",
      "blocks": [
        { "type": "column", "settings": { "heading": "Le Groupe" } },
        { "type": "column", "settings": { "heading": "Travailler avec nous" } },
        { "type": "column", "settings": { "heading": "Légal" } }
      ]
    }
  ]
}
{% endschema %}
