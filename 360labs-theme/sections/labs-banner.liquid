{%- comment -%} 360labs — Bannière (hero + visuel fusionnés) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} banner labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Bannière' }}">
  <div class="banner-bg">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2200 }}" alt="{{ section.settings.heading | strip_html }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:{{ section.settings.image_opacity | divided_by: 100.0 }}" loading="lazy">
    {%- endif -%}
  </div>
  {%- if section.settings.caption != blank -%}<div class="banner-cap">{{ section.settings.caption }}</div>{%- endif -%}
  <div class="wrap banner-in reveal">
    {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h1>{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
      <div class="hero-cta" style="margin-top:30px">
        {%- if section.settings.cta1_label != blank -%}<a class="btn btn-glass" href="{{ section.settings.cta1_url | default: '#' }}">{{ section.settings.cta1_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
        {%- if section.settings.cta2_label != blank -%}<a class="btn btn-soft" href="{{ section.settings.cta2_url | default: '#' }}">{{ section.settings.cta2_label }}</a>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Bannière",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "image_picker", "id": "image", "label": "Image de fond" },
    { "type": "range", "id": "image_opacity", "label": "Opacité de l'image", "min": 10, "max": 100, "step": 5, "unit": "%", "default": 60 },
    { "type": "text", "id": "caption", "label": "Légende (coin)", "default": "espace visuel · bannière" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Résultats" },
    { "type": "text", "id": "heading", "label": "Titre (HTML, .grad-on possible)", "default": "Des résultats qu'on <span class=\"grad-on\">assume</span>." },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Des marques transformées, des chiffres réels. Voici ce que produit un écosystème complet." },
    { "type": "text", "id": "cta1_label", "label": "Bouton 1" },
    { "type": "url", "id": "cta1_url", "label": "Lien bouton 1" },
    { "type": "text", "id": "cta2_label", "label": "Bouton 2" },
    { "type": "url", "id": "cta2_url", "label": "Lien bouton 2" }
  ],
  "presets": [ { "name": "360labs · Bannière" } ]
}
{% endschema %}
