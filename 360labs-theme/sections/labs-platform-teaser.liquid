{%- comment -%} 360labs — Teaser mystère de la plateforme (UI floutée + cryptic + waitlist) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Plateforme · teaser' }}">
  <div class="wrap">
    <div class="head reveal" style="max-width:640px;margin-bottom:32px">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>

    <div class="tease reveal">
      <div class="tease-blur" aria-hidden="true">
        <div class="fakeui">
          <div class="fk-side"><div class="fk-row lg"></div><div class="fk-row"></div><div class="fk-row"></div><div class="fk-row"></div><div class="fk-row"></div></div>
          <div class="fk-main">
            <div class="fk-cards"><div class="fk-card"></div><div class="fk-card"></div><div class="fk-card"></div></div>
            <div class="fk-bar"></div>
          </div>
        </div>
      </div>
      <div class="tease-veil">
        <div class="tease-lock"><svg viewBox="0 0 24 24"><rect x="5" y="11" width="14" height="9" rx="2"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg></div>
        {%- if section.settings.pill != blank -%}<span class="tease-pill">{{ section.settings.pill }}</span>{%- endif -%}
        {%- if section.settings.veil_title != blank -%}<b>{{ section.settings.veil_title }}</b>{%- endif -%}
        {%- if section.settings.veil_text != blank -%}<p>{{ section.settings.veil_text }}</p>{%- endif -%}
        {%- if section.settings.show_waitlist -%}
          {%- form 'customer', class: 'nl-form', style: 'max-width:380px;width:100%' -%}
            <input type="hidden" name="contact[tags]" value="waitlist, 360labs-plateforme">
            {%- if form.posted_successfully? -%}
              <p class="form-note" style="color:var(--accent-ink)">✓ Vous êtes sur la liste. On vous prévient au lancement.</p>
            {%- else -%}
              <input type="email" name="contact[email]" class="nl-input" placeholder="{{ section.settings.waitlist_placeholder }}" aria-label="E-mail" required>
              <button type="submit" class="btn btn-glass nl-btn">{{ section.settings.waitlist_button }}</button>
            {%- endif -%}
          {%- endform -%}
        {%- endif -%}
      </div>
    </div>

    {%- assign crys = section.blocks | where: 'type', 'cry' -%}
    {%- if crys.size > 0 -%}
      <div class="cryptic reveal" style="margin-top:22px">
        {%- for block in crys -%}
          <div class="cry" {{ block.shopify_attributes }}>
            <div class="cry-k">{{ block.settings.key }}</div>
            <b>{{ block.settings.title }}</b>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Teaser plateforme",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "waitlist" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La Plateforme · Bientôt" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Le copilote des marques e-commerce. En préparation." },
    { "type": "header", "content": "Voile (verrou)" },
    { "type": "text", "id": "pill", "label": "Pastille", "default": "Accès anticipé" },
    { "type": "text", "id": "veil_title", "label": "Titre du voile", "default": "Quelque chose se prépare." },
    { "type": "textarea", "id": "veil_text", "label": "Texte du voile", "default": "Une plateforme qui réunit vos données et vous dit quoi faire, chaque jour. Rejoignez la liste d'attente pour un accès anticipé." },
    { "type": "checkbox", "id": "show_waitlist", "label": "Afficher la liste d'attente", "default": true },
    { "type": "text", "id": "waitlist_placeholder", "label": "Placeholder e-mail", "default": "Votre e-mail" },
    { "type": "text", "id": "waitlist_button", "label": "Bouton", "default": "Rejoindre" }
  ],
  "blocks": [
    {
      "type": "cry",
      "name": "Carte cryptique",
      "settings": [
        { "type": "text", "id": "key", "label": "Clé (mono)", "default": "// 01" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Données unifiées" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Toutes vos sources réunies en un seul endroit." }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Teaser plateforme",
      "blocks": [
        { "type": "cry", "settings": { "key": "// 01", "title": "Données unifiées", "text": "Toutes vos sources réunies, lisibles d'un coup d'œil." } },
        { "type": "cry", "settings": { "key": "// 02", "title": "Copilote IA", "text": "Des recommandations quotidiennes, priorisées par impact." } },
        { "type": "cry", "settings": { "key": "// 03", "title": "Méthode du groupe", "text": "L'expérience de +3000 projets, encodée." } }
      ]
    }
  ]
}
{% endschema %}
