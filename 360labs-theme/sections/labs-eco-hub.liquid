{%- comment -%}
  360labs — Hub écosystème interactif
  Chaque bloc = une catégorie qui fait orbiter ses marques dans le cercle.
  La config est sérialisée en JSON et lue par labs-hub.js.
{%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="Hub écosystème">
  <div class="wrap">
    <div class="head reveal" style="max-width:780px;margin-bottom:12px">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="ecoH reveal" id="ecoH-{{ section.id }}">
      <div class="ecoH-list"></div>
      <div class="ecoH-hub">
        <div class="ecoH-ring">
          <div class="ecoH-glow"></div>
          <div class="ecoH-orbit"></div>
          <div class="ecoH-orbit r2"></div>
          <div class="ecoH-core">
            <span class="mark mark-40"><svg viewBox="0 0 40 40" fill="none"><g stroke="rgba(26,20,48,.5)" stroke-width="1.4"><circle cx="20" cy="20" r="13"></circle><path d="M7 20h26M20 7c4 4 4 22 0 26M20 7c-4 4-4 22 0 26M9.5 13h21M9.5 27h21"></path></g></svg></span>
            <span class="ecoH-corelbl">{{ section.settings.core_label }}</span>
          </div>
          <div class="ecoH-nodes"></div>
        </div>
        <div class="ecoH-detail"></div>
      </div>
      <script type="application/json">
        [
        {%- for block in section.blocks -%}
          {
            "kicker": {{ block.settings.kicker | json }},
            "cat": {{ block.settings.cat | json }},
            "title": {{ block.settings.title | json }},
            "count": {{ block.settings.count | json }},
            "arc": {{ block.settings.arc | default: 60 }},
            "phase": {{ block.settings.phase | default: -90 }},
            "desc": {{ block.settings.desc | json }},
            "chips": [
              {%- assign chips = block.settings.chips | split: ',' -%}
              {%- for c in chips -%}{{ c | strip | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
            ],
            "cta": { "label": {{ block.settings.cta_label | json }}, "href": {{ block.settings.cta_url | default: '' | json }} },
            "marks": [
              {%- assign mcount = 0 -%}
              {%- for i in (1..4) -%}
                {%- assign lbl = block.settings['mark' | append: i | append: '_label'] -%}
                {%- if lbl != blank -%}
                  {%- if mcount > 0 -%},{%- endif -%}
                  {%- assign mcount = mcount | plus: 1 -%}
                  {%- assign img = block.settings['mark' | append: i | append: '_image'] -%}
                  {%- assign asset = block.settings['mark' | append: i | append: '_logo'] -%}
                  {%- assign soft = block.settings['mark' | append: i | append: '_soft'] -%}
                  {%- assign letter = block.settings['mark' | append: i | append: '_letter'] -%}
                  {%- liquid
                    assign logo_url = ''
                    if img != blank
                      assign logo_url = img | image_url: width: 96
                    elsif asset != 'none' and asset != blank
                      assign logo_url = asset | asset_url
                    endif
                  -%}
                  { "t": {{ lbl | json }}, "l": {{ letter | default: '' | json }}{% if logo_url != '' %}, "logo": {{ logo_url | json }}{% endif %}{% if soft %}, "soft": true{% endif %}{% if block.settings['mark' | append: i | append: '_icon'] %}, "icon": "grid"{% endif %} }
                {%- endif -%}
              {%- endfor -%}
            ]
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
        ]
      </script>
    </div>
  </div>
</section>

