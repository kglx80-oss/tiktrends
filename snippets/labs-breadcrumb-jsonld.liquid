{%- comment -%} 360labs — Fil d'Ariane (BreadcrumbList) JSON-LD pour SEO/GEO {%- endcomment -%}
{%- assign base = shop.url -%}
{%- if request.page_type == 'article' -%}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
  {"@type":"ListItem","position":1,"name":"Accueil","item":{{ base | json }}},
  {"@type":"ListItem","position":2,"name":{{ blog.title | json }},"item":{{ base | append: blog.url | json }}},
  {"@type":"ListItem","position":3,"name":{{ article.title | json }},"item":{{ base | append: article.url | json }}}
  ]}
  </script>
{%- elsif request.page_type == 'blog' -%}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
  {"@type":"ListItem","position":1,"name":"Accueil","item":{{ base | json }}},
  {"@type":"ListItem","position":2,"name":{{ blog.title | json }},"item":{{ base | append: blog.url | json }}}
  ]}
  </script>
{%- elsif request.page_type == 'page' -%}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
  {"@type":"ListItem","position":1,"name":"Accueil","item":{{ base | json }}},
  {"@type":"ListItem","position":2,"name":{{ page.title | json }},"item":{{ base | append: page.url | json }}}
  ]}
  </script>
{%- endif -%}
