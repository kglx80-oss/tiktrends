{%- comment -%} 360labs — Étude de cas / preuve {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Étude de cas' }}">
  <div class="wrap cs-grid cs reveal">
    <div>
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.number != blank -%}<div class="cs-num grad-on">{{ section.settings.number }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.list != blank -%}
        <ul class="cs-list">
          {%- assign items = section.settings.list | newline_to_br | split: '<br />' -%}
          {%- for it in items -%}{%- assign t = it | strip -%}{%- if t != blank -%}<li>{{ t }}</li>{%- endif -%}{%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}<a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <figure class="figure cs-board">
        <div class="islab reveal">
          <svg class="islab-curve" viewBox="0 0 600 220" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="csCurve-{{ section.id }}" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#C9C2FF" stop-opacity=".5"></stop>
                <stop offset="1" stop-color="#C9C2FF" stop-opacity="0"></stop>
              </linearGradient>
            </defs>
            <path class="islab-area" d="M0,182 C100,176 150,150 250,116 C350,82 430,54 600,24 L600,220 L0,220 Z" fill="url(#csCurve-{{ section.id }})"></path>
            <path class="islab-line" pathLength="1" d="M0,182 C100,176 150,150 250,116 C350,82 430,54 600,24" fill="none"></path>
          </svg>
          <div class="islab-head">
            {%- if section.settings.board_title != blank -%}<div class="islab-title">{{ section.settings.board_title }}</div>{%- endif -%}
            {%- if section.settings.caption != blank -%}<div class="islab-sub">{{ section.settings.caption }}</div>{%- endif -%}
          </div>
          <div class="islab-rows">
            {%- for block in section.blocks -%}
              {%- assign digits = block.settings.value | replace: ',', '' | replace: ' ', '' | replace: '€', '' | strip -%}
              <div class="islab-row{% if block.settings.strong %} strong{% endif %}" {{ block.shopify_attributes }}>
                <span class="islab-rk">{{ block.settings.label }}</span>
                <span class="islab-rv"><span data-countup data-to="{{ digits }}" data-sep="1" data-locale="fr-FR">0</span> {{ section.settings.currency }}</span>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </figure>
    {%- else -%}
      <figure class="figure media-well">
        <div class="ph {{ section.settings.ratio }}">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_tag: loading: 'lazy', widths: '400, 600, 800, 1200, 1600' }}
          {%- else -%}
            <span>{{ section.settings.placeholder }}</span>
          {%- endif -%}
        </div>
      </figure>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Étude de cas",
  "tag": "section",
  "class": "labs-shopify-section",
  "max_blocks": 14,
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "resultats" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Preuve · Étude de cas" },
    { "type": "text", "id": "number", "label": "Grand chiffre (dégradé)", "default": "+850 %" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Enissati. La marque avait le potentiel, on a construit l'écosystème qui l'a libéré, en 6 mois." },
    { "type": "textarea", "id": "list", "label": "Liste (une ligne par item)", "default": "Refonte complète du site\nNouveaux supports visuels\nLancement des publicités\nStratégie d'emailing & CRM" },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Voir nos résultats" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-soft", "label": "Discret" }, { "value": "btn-glass", "label": "Iridescent" } ], "default": "btn-soft" },
    { "type": "header", "content": "Tableau de résultats (compte de résultat)" },
    { "type": "paragraph", "content": "Ajoutez des lignes « Ligne » pour afficher le tableau animé avec courbe de croissance. Sans ligne, l'espace média/photo s'affiche à la place." },
    { "type": "text", "id": "board_title", "label": "Titre du tableau", "default": "Compte de résultat" },
    { "type": "text", "id": "caption", "label": "Sous-titre", "default": "Enissati · 6 mois" },
    { "type": "text", "id": "currency", "label": "Symbole monétaire (à droite)", "default": "€" },
    { "type": "header", "content": "Média (fallback si aucune ligne)" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "ratio", "label": "Format", "options": [ { "value": "", "label": "Paysage 4/3" }, { "value": "tall", "label": "Portrait 3/4" }, { "value": "wide", "label": "Large 16/9" }, { "value": "sq", "label": "Carré" } ], "default": "" },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "visuel marque · Enissati" }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Ligne",
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé", "default": "Ventes totales" },
        { "type": "text", "id": "value", "label": "Montant (chiffres)", "default": "970209" },
        { "type": "checkbox", "id": "strong", "label": "Ligne mise en avant (sous-total / total)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Étude de cas",
      "blocks": [
        { "type": "metric", "settings": { "label": "Ventes totales", "value": "970209" } },
        { "type": "metric", "settings": { "label": "Codes de réduction", "value": "56759" } },
        { "type": "metric", "settings": { "label": "Remboursements", "value": "11266" } },
        { "type": "metric", "settings": { "label": "Taxes", "value": "158700" } },
        { "type": "metric", "settings": { "label": "Ventes nettes", "value": "811509", "strong": true } },
        { "type": "metric", "settings": { "label": "Coût des marchandises", "value": "214272" } },
        { "type": "metric", "settings": { "label": "Coûts marketing", "value": "235042" } },
        { "type": "metric", "settings": { "label": "Marge sur coûts variables", "value": "362195", "strong": true } },
        { "type": "metric", "settings": { "label": "Charges d'exploitation", "value": "75676" } },
        { "type": "metric", "settings": { "label": "Bénéfice net", "value": "286519", "strong": true } }
      ]
    }
  ]
}
{% endschema %}
