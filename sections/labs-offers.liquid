{%- comment -%} 360labs — Offres / services (grille 3 colonnes) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Offres' }}">
  <div class="wrap">
    <div class="head reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="offer-grid reveal">
      {%- for block in section.blocks -%}
        <div class="offer" {{ block.shopify_attributes }}>
          <div class="offer-ic">
            {%- case block.settings.icon -%}
              {%- when 'globe' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"></path></svg>
              {%- when 'bolt' -%}<svg viewBox="0 0 24 24"><path d="M13 3 4 14h7l-1 7 9-11h-7z"></path></svg>
              {%- when 'chart' -%}<svg viewBox="0 0 24 24"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"></path></svg>
              {%- when 'shield' -%}<svg viewBox="0 0 24 24"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"></path></svg>
              {%- when 'tshirt' -%}<svg viewBox="0 0 24 24"><path d="M8 4l-5 3 2 4 3-1v10h8V10l3 1 2-4-5-3a4 4 0 0 1-8 0z"></path></svg>
              {%- else -%}<svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="3"></rect><path d="M9 9h6M9 13h6"></path></svg>
            {%- endcase -%}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.by != blank -%}<span class="by">{{ block.settings.by }}</span>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div style="margin-top:40px"><a class="btn btn-glass" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Offres",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "L'offre Entreprises" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Le groupe au service des entreprises." },
    { "type": "text", "id": "cta_label", "label": "Bouton bas de section", "default": "Parler à un expert" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" }
  ],
  "blocks": [
    {
      "type": "offer",
      "name": "Offre",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [ {"value":"globe","label":"Site / Web"}, {"value":"bolt","label":"Automatisation"}, {"value":"chart","label":"Acquisition"}, {"value":"shield","label":"Image / Marque"}, {"value":"tshirt","label":"Textile"}, {"value":"box","label":"Générique"} ], "default": "globe" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Site & présence digitale" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Un site professionnel qui génère des contrats." },
        { "type": "text", "id": "by", "label": "Badge (par...)", "default": "par GLX" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Offres",
      "blocks": [
        { "type": "offer", "settings": { "icon": "globe", "title": "Site & présence digitale", "text": "Un site professionnel qui inspire confiance et génère des contrats.", "by": "par GLX" } },
        { "type": "offer", "settings": { "icon": "chart", "title": "Acquisition B2B", "text": "Des campagnes pour générer des leads qualifiés.", "by": "par Melie" } },
        { "type": "offer", "settings": { "icon": "bolt", "title": "Systèmes & automatisation", "text": "Des process automatisés qui tournent sans vous.", "by": "par Websitz" } },
        { "type": "offer", "settings": { "icon": "shield", "title": "Image de marque", "text": "Une identité forte et cohérente sur tous vos supports.", "by": "par 360labs" } },
        { "type": "offer", "settings": { "icon": "tshirt", "title": "Textile & merch", "text": "Vêtements et personnalisation sur-mesure, à Laval.", "by": "par Apollon" } }
      ]
    }
  ]
}
{% endschema %}
