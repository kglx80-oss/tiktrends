{%- comment -%} 360labs — Teaser plateforme (texte + bénéfices) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section{% if section.settings.atmos %} atmos atmos--left{% endif %}" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Plateforme' }}">
  {%- if section.settings.atmos -%}
    {%- assign atmos_src = 'labs-atmos-platform.png' | asset_url -%}
    {%- if section.settings.atmos_image != blank -%}{%- assign atmos_src = section.settings.atmos_image | image_url: width: 2400 -%}{%- endif -%}
    <div class="atmos-bg" aria-hidden="true">
      <img class="atmos-img" src="{{ atmos_src }}" alt="" loading="lazy">
      <span class="atmos-bloom"></span><span class="atmos-grain"></span><span class="atmos-vig"></span>
    </div>
  {%- endif -%}
  <div class="wrap tool reveal">
    <div>
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
      {%- if section.settings.cta_label != blank -%}<a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
    </div>
    <div class="bens">
      {%- for block in section.blocks -%}
        <div class="ben" {{ block.shopify_attributes }}>
          <span class="ben-n">{{ block.settings.number | default: forloop.index | prepend: '0' }}</span>
          <div><b>{{ block.settings.title }}</b><p>{{ block.settings.text }}</p></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "360labs · Plateforme",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "checkbox", "id": "atmos", "label": "Fond atmosphérique (profondeur)", "default": true },
    { "type": "image_picker", "id": "atmos_image", "label": "Image atmosphérique (optionnel)" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "plateforme" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La Plateforme · Bientôt" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Le copilote des marques e-commerce arrive." },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Bientôt : pilotez toute votre marque e-commerce depuis un seul endroit, avec une IA qui pense comme nos experts." },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Rejoindre la liste d'attente" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-glass", "label": "Iridescent" }, { "value": "btn-soft", "label": "Discret" } ], "default": "btn-glass" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "settings": [
        { "type": "text", "id": "number", "label": "Numéro" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Titre du bénéfice" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Description du bénéfice." }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Plateforme",
      "blocks": [
        { "type": "benefit", "settings": { "number": "01", "title": "Tout votre business, en un seul endroit.", "text": "Vos données réunies et lisibles, sans jongler entre dix outils." } },
        { "type": "benefit", "settings": { "number": "02", "title": "Un copilote qui vous dit quoi faire.", "text": "Chaque jour, une lecture claire de votre marque et des actions prioritaires." } },
        { "type": "benefit", "settings": { "number": "03", "title": "L'intelligence du groupe, à votre service.", "text": "La méthode qui a fait grandir +3000 projets, mise dans une plateforme." } }
      ]
    }
  ]
}
{% endschema %}
