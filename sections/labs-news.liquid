{%- comment -%} 360labs — Actualité / Journal (cartes + agenda + newsletter) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Actualité' }}">
  <div class="wrap">
    <div class="head reveal" style="max-width:600px">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
    </div>
    <div class="news-grid reveal">
      <div class="news-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'article' -%}
            <a class="ncard" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
              <div class="ph wide">
                {%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400, 600, 800, 1000', alt: block.settings.title }}{%- else -%}<span>{{ block.settings.placeholder | default: 'visuel article' }}</span>{%- endif -%}
              </div>
              <div class="ncard-body">
                {%- if block.settings.category != blank -%}<span class="ncat">{{ block.settings.category }}</span>{%- endif -%}
                <h3>{{ block.settings.title }}</h3>
                {%- if block.settings.date != blank -%}<span class="ndate">{{ block.settings.date }}</span>{%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <aside class="agenda">
        <div class="agenda-head">
          <b>{{ section.settings.agenda_title }}</b>
          <span class="live"><span class="dot"></span>{{ section.settings.agenda_badge }}</span>
        </div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'topic' -%}
            <a class="ai" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
              <div class="ai-main"><b>{{ block.settings.title }}</b><span>{{ block.settings.subtitle }}</span></div>
              <span class="ai-go"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></span>
            </a>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.nl_title != blank -%}
          <div class="agenda-foot">
            <div class="nl">
              <b>{{ section.settings.nl_title }}</b>
              {%- if section.settings.nl_text != blank -%}<p>{{ section.settings.nl_text }}</p>{%- endif -%}
              {%- form 'customer', class: 'nl-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter, 360labs-journal">
                {%- if form.posted_successfully? -%}
                  <p class="form-note" style="color:var(--accent-ink)">Merci, votre inscription est confirmée.</p>
                {%- else -%}
                  <input type="email" name="contact[email]" class="nl-input" placeholder="{{ section.settings.nl_placeholder }}" aria-label="E-mail" required>
                  <button type="submit" class="btn btn-glass nl-btn">{{ section.settings.nl_button }}</button>
                {%- endif -%}
              {%- endform -%}
            </div>
          </div>
        {%- endif -%}
      </aside>
    </div>
    {%- if section.settings.foot_text != blank or section.settings.foot_cta_label != blank -%}
      <div class="news-foot reveal">
        {%- if section.settings.foot_text != blank -%}<p>{{ section.settings.foot_text }}</p>{%- endif -%}
        {%- if section.settings.foot_cta_label != blank -%}<a class="btn btn-glass" href="{{ section.settings.foot_cta_url | default: '#' }}">{{ section.settings.foot_cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Actualité",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "actualite" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Le journal du groupe" },
    { "type": "text", "id": "heading", "label": "Titre (HTML, .grad-on possible)", "default": "Notre <span class=\"grad-on\">actualité</span>." },
    { "type": "textarea", "id": "lede", "label": "Accroche", "default": "Lancements de marques, résultats, coulisses de l'écosystème et regards sur l'e-commerce." },
    { "type": "header", "content": "Agenda (colonne)" },
    { "type": "text", "id": "agenda_title", "label": "Titre agenda", "default": "Explorer par sujet" },
    { "type": "text", "id": "agenda_badge", "label": "Badge", "default": "Journal" },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "nl_title", "label": "Titre newsletter", "default": "La newsletter du groupe" },
    { "type": "textarea", "id": "nl_text", "label": "Texte", "default": "Nos analyses e-commerce et les coulisses de l'écosystème, une fois par mois." },
    { "type": "text", "id": "nl_placeholder", "label": "Placeholder e-mail", "default": "Votre e-mail" },
    { "type": "text", "id": "nl_button", "label": "Bouton", "default": "S'inscrire" },
    { "type": "header", "content": "Pied de section" },
    { "type": "textarea", "id": "foot_text", "label": "Texte", "default": "Un espace éditorial qui travaille votre visibilité, SEO classique et GEO, au service de chaque marque du groupe." },
    { "type": "text", "id": "foot_cta_label", "label": "Bouton", "default": "Voir tout le journal" },
    { "type": "url", "id": "foot_cta_url", "label": "Lien bouton" }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Carte article",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "visuel article · à fournir" },
        { "type": "text", "id": "category", "label": "Catégorie", "default": "Étude de cas" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Titre de l'article" },
        { "type": "text", "id": "date", "label": "Date", "default": "12 juin 2026" },
        { "type": "url", "id": "url", "label": "Lien" }
      ]
    },
    {
      "type": "topic",
      "name": "Sujet (agenda)",
      "settings": [
        { "type": "text", "id": "title", "label": "Titre", "default": "Études de cas" },
        { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Résultats & transformations de marques" },
        { "type": "url", "id": "url", "label": "Lien" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Actualité",
      "blocks": [
        { "type": "article", "settings": { "category": "Étude de cas", "title": "Enissati : +850 % de chiffre d'affaires en 6 mois.", "date": "12 juin 2026" } },
        { "type": "article", "settings": { "category": "Coulisses", "title": "Focuslabs : pourquoi nous lançons nos propres marques.", "date": "28 mai 2026" } },
        { "type": "article", "settings": { "category": "Acquisition", "title": "TikTok Shop : le guide pour scaler une marque en 2026.", "date": "15 mai 2026" } },
        { "type": "article", "settings": { "category": "Groupe", "title": "La Plateforme : ce que prépare le copilote des marques.", "date": "2 mai 2026" } },
        { "type": "topic", "settings": { "title": "Études de cas", "subtitle": "Résultats & transformations de marques" } },
        { "type": "topic", "settings": { "title": "Acquisition & paid", "subtitle": "Meta, Google, TikTok, scaling rentable" } },
        { "type": "topic", "settings": { "title": "Site & conversion", "subtitle": "CRO, parcours d'achat, fidélisation" } },
        { "type": "topic", "settings": { "title": "Coulisses du groupe", "subtitle": "Focuslabs, méthode, vision e-commerce" } }
      ]
    }
  ]
}
{% endschema %}
