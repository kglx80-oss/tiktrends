{%- comment -%} 360labs — Calculateur de multiple (EBITDA/SDE) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Multiple' }}" data-multiple>
  <div class="wrap">
    <div class="head reveal" style="max-width:680px">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
    </div>
    <div class="val-card reveal">
      <div class="val-inputs">
        <label class="val-lab">Bénéfice annuel (EBITDA / SDE)
          <span class="val-field"><i>€</i><input type="number" id="mProfit" value="120000" min="0" step="5000" inputmode="numeric"></span>
        </label>
        <label class="val-lab">Croissance
          <select id="mGrowth"><option value="decline">En baisse</option><option value="stable">Stable</option><option value="up" selected>En croissance</option><option value="fast">Forte croissance</option></select>
        </label>
        <label class="val-lab">Diversification des canaux
          <select id="mChannels"><option value="mono">Un seul canal</option><option value="multi" selected>Plusieurs canaux</option><option value="diversified">Bien diversifié</option></select>
        </label>
        <label class="val-lab">Dépendance au fondateur
          <select id="mFounder"><option value="high">Forte</option><option value="medium" selected>Moyenne</option><option value="low">Faible (autonome)</option></select>
        </label>
        <label class="val-lab">Revenus récurrents / abonnement
          <select id="mRecurring"><option value="none" selected>Aucun</option><option value="some">Une partie</option><option value="high">Élevés</option></select>
        </label>
      </div>
      <div class="val-result">
        <div class="val-result-l">Multiple estimé</div>
        <div class="val-range"><span id="mMult">—</span></div>
        <div class="val-meta">Valorisation : <b id="mVal">—</b><br>Fourchette : <b id="mRange">—</b></div>
        {%- if section.settings.cta_label != blank -%}<a class="btn btn-glass" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
        <p class="val-disc">{{ section.settings.disclaimer | default: 'Le multiple dépend surtout de la qualité de la marque (croissance, canaux, autonomie, récurrence). Estimation indicative.' }}</p>
      </div>
    </div>
  </div>
  <script src="{{ 'labs-tools.js' | asset_url }}" defer="defer"></script>
</section>

{% schema %}
{
  "name": "360labs · Multiple",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "multiple" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Calculateur" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Quel multiple pour votre marque ?" },
    { "type": "textarea", "id": "lede", "label": "Accroche", "default": "Le prix de cession = bénéfice annuel × multiple. Voyez comment la qualité de votre marque fait bouger ce multiple." },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Faire évaluer ma marque" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "textarea", "id": "disclaimer", "label": "Mention" }
  ],
  "presets": [ { "name": "360labs · Multiple" } ]
}
{% endschema %}
