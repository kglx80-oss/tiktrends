{%- comment -%} 360labs — Ownership / Skin in the game {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Ownership' }}">
  <div class="wrap own-grid reveal">
    <div class="own-txt">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- endif -%}
      {%- if section.settings.cta_label != blank -%}<a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
    </div>
    <div class="own-panel">
      {%- for block in section.blocks -%}
        <div class="own-card{% if block.settings.wide %} tall{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != 'none' -%}
            <span class="own-ic">
              {%- case block.settings.icon -%}
                {%- when 'gem' -%}<svg viewBox="0 0 24 24"><path d="M6 3h12l3 6-9 12L3 9z"/><path d="M3 9h18M9 3 7.5 9 12 21M15 3l1.5 6L12 21"/></svg>
                {%- when 'coins' -%}<svg viewBox="0 0 24 24"><ellipse cx="9" cy="7" rx="6" ry="3"/><path d="M3 7v5c0 1.7 2.7 3 6 3s6-1.3 6-3V7"/><path d="M9 12v5c0 1.7 2.7 3 6 3s6-1.3 6-3v-5c0-1.7-2.7-3-6-3"/></svg>
                {%- when 'flask' -%}<svg viewBox="0 0 24 24"><path d="M9 3h6M10 3v6l-5 9a2 2 0 0 0 1.8 3h10.4a2 2 0 0 0 1.8-3l-5-9V3"/><path d="M7.5 15h9"/></svg>
                {%- when 'shield' -%}<svg viewBox="0 0 24 24"><path d="M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
                {%- when 'target' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/></svg>
                {%- when 'rocket' -%}<svg viewBox="0 0 24 24"><path d="M5 15c-1.5 1.5-2 5-2 5s3.5-.5 5-2M9 11a8 8 0 0 1 9-7c1 5-2 8-7 9zM12 8a2 2 0 1 0 4 0 2 2 0 0 0-4 0z"/></svg>
                {%- when 'bolt' -%}<svg viewBox="0 0 24 24"><path d="M13 3 4 14h7l-1 7 9-11h-7z"/></svg>
                {%- when 'chart' -%}<svg viewBox="0 0 24 24"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/></svg>
                {%- when 'wallet' -%}<svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18M16 14h2"/></svg>
                {%- else -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2"/></svg>
              {%- endcase -%}
            </span>
          {%- endif -%}
          {%- if block.settings.tag != blank -%}<div class="otag"><span class="dot"></span>{{ block.settings.tag }}</div>{%- endif -%}
          {%- if block.settings.number != blank -%}<div class="ocn">{{ block.settings.number }}</div>{%- endif -%}
          {%- if block.settings.title != blank -%}<b>{{ block.settings.title }}</b>{%- endif -%}
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- style -%}
  .own-ic{width:42px;height:42px;border-radius:12px;display:grid;place-items:center;margin-bottom:16px;
    background:color-mix(in oklab,var(--accent-ink) 16%,transparent);
    border:1px solid color-mix(in oklab,var(--accent-ink) 32%,transparent)}
  .own-ic svg{width:21px;height:21px;stroke:var(--accent-ink);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .own-card.tall .own-ic{margin-bottom:14px}
{%- endstyle -%}

{% schema %}
{
  "name": "360labs · Ownership",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "skin" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Focuslabs · Ownership" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "On ne vous conseille pas depuis les gradins. On joue notre propre argent." },
    { "type": "richtext", "id": "text", "label": "Paragraphes", "default": "<p>Avec <strong>Focuslabs</strong>, notre incubateur, nous lançons et détenons nos propres marques e-commerce. Pas des cas d'école : de vraies marques, avec notre trésorerie, nos stocks et nos arbitrages.</p><p>Résultat : on vit les mêmes décisions que vous, la marge, le scaling, le cash. C'est pour ça qu'on vous parle en <strong>propriétaire</strong>, pas en prestataire.</p>" },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Comprendre la thèse du Groupe" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-glass", "label": "Iridescent" }, { "value": "btn-soft", "label": "Discret" } ], "default": "btn-glass" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carte",
      "settings": [
        { "type": "checkbox", "id": "wide", "label": "Carte large (pleine largeur)", "default": false },
        { "type": "select", "id": "icon", "label": "Icône", "options": [
          { "value": "none", "label": "Aucune" },
          { "value": "gem", "label": "Diamant (capital)" },
          { "value": "coins", "label": "Pièces (argent)" },
          { "value": "flask", "label": "Éprouvette (R&D)" },
          { "value": "shield", "label": "Bouclier" },
          { "value": "target", "label": "Cible" },
          { "value": "rocket", "label": "Fusée" },
          { "value": "bolt", "label": "Éclair" },
          { "value": "chart", "label": "Graphique" },
          { "value": "wallet", "label": "Portefeuille" }
        ], "default": "none" },
        { "type": "text", "id": "tag", "label": "Étiquette (avec point)" },
        { "type": "text", "id": "number", "label": "Grand chiffre" },
        { "type": "text", "id": "title", "label": "Titre" },
        { "type": "textarea", "id": "text", "label": "Texte" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Ownership",
      "blocks": [
        { "type": "card", "settings": { "wide": true, "icon": "gem", "tag": "Skin in the game", "title": "Nos marques, notre capital.", "text": "On conçoit, on finance et on opère des marques e-commerce en propre. Quand on vous recommande une décision, on l'a déjà prise pour nous." } },
        { "type": "card", "settings": { "icon": "coins", "number": "100 %", "title": "Du capital engagé", "text": "Nos marques sont financées par le groupe, pas par des clients." } },
        { "type": "card", "settings": { "icon": "flask", "number": "R&D", "title": "Terrain d'essai", "text": "Chaque levier est validé en interne avant d'arriver chez vous." } }
      ]
    }
  ]
}
{% endschema %}
