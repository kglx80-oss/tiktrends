{%- comment -%} 360labs — Gabarit d'article premium (sommaire actif, progression, partage, points clés, auteur, articles liés, schémas Article + FAQPage) {%- endcomment -%}
{%- assign words = article.content | strip_html | split: ' ' | size -%}
{%- assign rt = words | divided_by: 200 -%}
{%- if rt < 1 -%}{%- assign rt = 1 -%}{%- endif -%}
{%- assign cat = article.tags.first -%}
{%- assign keys = article.metafields.custom.key_takeaways.value -%}
<article class="labs theme-{{ section.settings.theme }} pad labs-article" data-article data-screen-label="Article">
  <div class="art-progress" aria-hidden="true"><span id="artProgress"></span></div>
  <div class="wrap art-wrap">

    <nav class="art-crumb reveal" aria-label="Fil d'Ariane">
      <a href="{{ routes.root_url }}">Accueil</a>
      <span>›</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      {%- if cat != blank -%}<span>›</span><a href="{{ blog.url }}/tagged/{{ cat | handleize }}">{{ cat }}</a>{%- endif -%}
    </nav>

    <header class="art-head reveal">
      {%- if cat != blank -%}<span class="art-cat">{{ cat }}</span>{%- endif -%}
      <h1>{{ article.title }}</h1>
      {%- if article.excerpt != blank -%}<p class="art-lede">{{ article.excerpt | strip_html }}</p>{%- endif -%}
      <div class="art-meta">
        <span class="art-author-mini">
          {%- if section.settings.author_image != blank -%}
            <img class="art-av-img" src="{{ section.settings.author_image | image_url: width: 80 }}" alt="{{ section.settings.author_name }}" width="30" height="30">
          {%- else -%}
            <span class="art-av">{{ section.settings.author_name | slice: 0 }}</span>
          {%- endif -%}
          <b>{{ section.settings.author_name }}</b>
        </span>
        <span class="art-dot">·</span>
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%-d %B %Y' }}</time>
        <span class="art-dot">·</span>
        <span>{{ rt }} min de lecture</span>
      </div>
    </header>

    {%- if article.image -%}
      <figure class="art-cover reveal"><img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.title }}"></figure>
    {%- else -%}
      <div class="art-cover art-cover--grad reveal" aria-hidden="true"><span class="acg-glow"></span></div>
    {%- endif -%}

    <div class="art-layout">
      <aside class="art-aside reveal">
        <div class="art-toc">
          <div class="art-toc-title">Sommaire</div>
          <nav id="artToc"></nav>
        </div>
        <div class="art-share">
          <span class="art-share-l">Partager</span>
          <a class="art-sh" href="https://www.linkedin.com/sharing/share-offsite/?url={{ canonical_url | url_encode }}" target="_blank" rel="noopener" aria-label="Partager sur LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM3.5 8.5h3v12h-3zm5 0h2.88v1.64h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2 3.6 4.6v7.32h-3v-6.49c0-1.55-.03-3.54-2.16-3.54-2.16 0-2.49 1.69-2.49 3.43v6.6h-3z"/></svg></a>
          <a class="art-sh" href="https://twitter.com/intent/tweet?url={{ canonical_url | url_encode }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Partager sur X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.1 8.12L23 22h-6.56l-5.14-6.72L5.4 22H2.28l7.6-8.69L1.6 2h6.72l4.65 6.15zm-1.15 18.1h1.7L7.3 3.8H5.46z"/></svg></a>
          <button type="button" class="art-sh art-copy" data-copy="{{ canonical_url }}" aria-label="Copier le lien"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></button>
        </div>
      </aside>

      <div class="art-body" id="artBody">
        {%- if section.settings.show_keys and keys != blank -%}
          <div class="art-keys">
            <div class="art-keys-t">{{ section.settings.keys_title | default: 'Points clés' }}</div>
            <ul>
              {%- assign klines = keys | newline_to_br | split: '<br />' -%}
              {%- for l in klines -%}{%- assign lt = l | strip -%}{%- if lt != blank -%}<li>{{ lt }}</li>{%- endif -%}{%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {{ article.content }}

        {%- if section.settings.cta_label != blank -%}
          <div class="art-cta">
            {%- if section.settings.cta_text != blank -%}<p>{{ section.settings.cta_text }}</p>{%- endif -%}
            <a class="btn btn-glass" href="{{ section.settings.cta_url | default: '/pages/audit' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_author_box -%}
      <div class="art-author reveal">
        {%- if section.settings.author_image != blank -%}
          <img class="art-au-img" src="{{ section.settings.author_image | image_url: width: 160 }}" alt="{{ section.settings.author_name }}" width="60" height="60">
        {%- else -%}
          <span class="art-av lg">{{ section.settings.author_name | slice: 0 }}</span>
        {%- endif -%}
        <div>
          <div class="art-au-name">{{ section.settings.author_name }}</div>
          {%- if section.settings.author_role != blank -%}<div class="art-au-role">{{ section.settings.author_role }}</div>{%- endif -%}
          {%- if section.settings.author_bio != blank -%}<p class="art-au-bio">{{ section.settings.author_bio }}</p>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_related and blog.articles_count > 1 -%}
      <div class="art-related reveal">
        <div class="art-rel-head"><h2>{{ section.settings.related_title | default: 'À lire aussi' }}</h2><a href="{{ blog.url }}">Tout le journal →</a></div>
        <div class="art-rel-grid">
          {%- assign count = 0 -%}
          {%- for a in blog.articles -%}
            {%- if a.id != article.id and count < 3 -%}
              <a class="art-rel-card" href="{{ a.url }}">
                <span class="art-rel-ph">{%- if a.image -%}<img src="{{ a.image | image_url: width: 500 }}" loading="lazy" alt="{{ a.title }}">{%- else -%}<span class="art-rel-grad"></span>{%- endif -%}</span>
                <span class="art-rel-cat">{{ a.tags.first | default: 'Article' }}</span>
                <span class="art-rel-title">{{ a.title }}</span>
              </a>
              {%- assign count = count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <button type="button" class="art-totop" aria-label="Revenir en haut"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M6 11l6-6 6 6"></path></svg></button>

  <script type="application/ld+json">{{ article | structured_data }}</script>
  <script src="{{ 'labs-article.js' | asset_url }}" defer="defer"></script>
</article>

{% schema %}
{
  "name": "360labs · Article",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "header", "content": "Auteur (E-E-A-T)" },
    { "type": "text", "id": "author_name", "label": "Nom de l'auteur", "default": "L'équipe 360labs" },
    { "type": "text", "id": "author_role", "label": "Rôle / fonction", "default": "Groupe de croissance e-commerce" },
    { "type": "textarea", "id": "author_bio", "label": "Bio auteur", "default": "Depuis 2019, 360labs construit, possède et propulse des marques e-commerce via ses agences, son incubateur et sa plateforme. Nos contenus sont issus de notre travail sur +3000 projets." },
    { "type": "image_picker", "id": "author_image", "label": "Photo / logo auteur (optionnel)" },
    { "type": "checkbox", "id": "show_author_box", "label": "Afficher l'encadré auteur", "default": true },
    { "type": "header", "content": "Points clés" },
    { "type": "checkbox", "id": "show_keys", "label": "Afficher l'encadré « Points clés » (metafield custom.key_takeaways, une ligne = un point)", "default": true },
    { "type": "text", "id": "keys_title", "label": "Titre de l'encadré", "default": "Points clés" },
    { "type": "header", "content": "Articles liés" },
    { "type": "checkbox", "id": "show_related", "label": "Afficher les articles liés", "default": true },
    { "type": "text", "id": "related_title", "label": "Titre", "default": "À lire aussi" },
    { "type": "header", "content": "Appel à l'action (fin d'article)" },
    { "type": "text", "id": "cta_text", "label": "Texte", "default": "Vous voulez faire grandir votre marque e-commerce ?" },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Demander un audit gratuit" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton", "default": "/pages/audit" }
  ],
  "presets": [ { "name": "360labs · Article" } ]
}
{% endschema %}
