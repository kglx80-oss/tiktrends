{%- comment -%} 360labs — Grille d'agences (cartes) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Agences' }}">
  <div class="wrap">
    <div class="head reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="ag-grid reveal">
      {%- for block in section.blocks -%}
        <div class="ag" {{ block.shopify_attributes }}>
          <div class="ag-top">
            <span class="ag-tile">{% if block.settings.logo != blank %}{{ block.settings.logo | image_tag: widths: '46, 92, 138', alt: block.settings.name, style: 'width:100%;height:100%;object-fit:cover;border-radius:inherit' }}{% else %}{{ block.settings.tile }}{% endif %}</span>
            <div><div class="ag-name">{{ block.settings.name }}</div><div class="ag-base">{{ block.settings.base }}</div></div>
          </div>
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
          {%- if block.settings.tags != blank -%}
            <div class="ag-tags">{%- assign tags = block.settings.tags | split: ',' -%}{%- for t in tags -%}<span class="tag">{{ t | strip }}</span>{%- endfor -%}</div>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a class="ag-link" href="{{ block.settings.link_url | default: '#' }}">{{ block.settings.link_label }} <svg viewBox="0 0 24 24"><path d="M7 17 17 7M9 7h8v8"></path></svg></a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div style="margin-top:40px"><a class="btn btn-soft" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "360labs · Agences",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "agences" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Les agences" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Quatre expertises. Une seule direction." },
    { "type": "text", "id": "cta_label", "label": "Bouton bas de section", "default": "Découvrir l'écosystème" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" }
  ],
  "blocks": [
    {
      "type": "agency",
      "name": "Agence",
      "settings": [
        { "type": "text", "id": "tile", "label": "Initiale", "default": "G" },
        { "type": "image_picker", "id": "logo", "label": "Logo (optionnel)" },
        { "type": "text", "id": "name", "label": "Nom", "default": "GLX" },
        { "type": "text", "id": "base", "label": "Baseline", "default": "Le site qui vend." },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Création et optimisation de sites e-commerce qui convertissent et fidélisent." },
        { "type": "text", "id": "tags", "label": "Tags (séparés par virgule)", "default": "Site / CRO, CRM, Accompagnement" },
        { "type": "text", "id": "link_label", "label": "Lien — libellé", "default": "Visiter GLX" },
        { "type": "url", "id": "link_url", "label": "Lien — URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Agences",
      "blocks": [
        { "type": "agency", "settings": { "tile": "G", "name": "GLX", "base": "Le site qui vend.", "text": "Création et optimisation de sites e-commerce qui convertissent et fidélisent. La première société du groupe, depuis 2019.", "tags": "Site / CRO, CRM, Accompagnement", "link_label": "Visiter GLX" } },
        { "type": "agency", "settings": { "tile": "T", "name": "TikTrends", "base": "La marque qui scrolle et qui vend.", "text": "Transforme TikTok en machine à vendre : social commerce, studio créatif et créateurs calibrés pour la conversion.", "tags": "TikTok Shop, Studio & UGC, Live commerce", "link_label": "Visiter TikTrends" } },
        { "type": "agency", "settings": { "tile": "W", "name": "Websitz", "base": "Les systèmes qui tournent sans vous.", "text": "Construit des systèmes digitaux rentables et automatisés, et porte l'angle B2B du groupe.", "tags": "Systèmes & data, Automatisation, Acquisition B2B", "link_label": "Visiter Websitz" } },
        { "type": "agency", "settings": { "tile": "M", "name": "Melie", "base": "L'acquisition rentable.", "text": "Pilote vos campagnes payantes pour une acquisition stable et profitable, sur toutes les régies.", "tags": "Meta · Google · TikTok, Creative strategy, Scaling", "link_label": "Visiter Melie" } }
      ]
    }
  ]
}
{% endschema %}
