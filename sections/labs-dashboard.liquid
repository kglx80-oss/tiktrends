{%- comment -%}
  360labs — Mockup dashboard animé (style "produit / SaaS")
  Inspiré des dashboards live : courbe animée, scores sociaux, grille produits,
  pastille "live" qui pulse, toast "nouvelle marque". 100% CSS/SVG, léger.
{%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Dashboard' }}">
  <div class="wrap ld-grid reveal">
    <div class="ld-intro">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p class="lede" style="max-width:460px">{{ section.settings.text }}</p>{%- endif -%}
      {%- if section.settings.cta_label != blank -%}<a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}" style="margin-top:30px">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
    </div>

    <div class="ld-stage">
      <div class="ld-app" aria-hidden="true">
        <div class="ld-chrome"><span class="ld-dot r"></span><span class="ld-dot y"></span><span class="ld-dot g"></span><span class="ld-url">{{ section.settings.domain | default: '360labs.app' }}</span></div>
        <div class="ld-body">
          <div class="ld-rail"><span></span><span class="on"></span><span></span><span></span><span></span></div>
          <div class="ld-main">
            <div class="ld-card ld-chartcard">
              <div class="ld-h"><span>{{ section.settings.metric_label | default: 'Publicités live' }}</span><b class="ld-live"><i></i>{{ section.settings.metric_value | default: '6 559' }}</b></div>
              <svg class="ld-chart" viewBox="0 0 520 170" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="ldArea" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#AEB6FF" stop-opacity=".55"/>
                    <stop offset="1" stop-color="#AEB6FF" stop-opacity="0"/>
                  </linearGradient>
                  <linearGradient id="ldLine" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0" stop-color="#7DA8FF"/><stop offset=".5" stop-color="#C9A8FF"/><stop offset="1" stop-color="#F8B4D9"/>
                  </linearGradient>
                </defs>
                <path class="ld-area" d="M0,130 C50,110 80,55 130,72 C185,90 210,140 260,120 C320,96 350,38 400,66 C450,93 480,150 520,118 L520,170 L0,170 Z" fill="url(#ldArea)"/>
                <path class="ld-stroke" d="M0,130 C50,110 80,55 130,72 C185,90 210,140 260,120 C320,96 350,38 400,66 C450,93 480,150 520,118" fill="none" stroke="url(#ldLine)" stroke-width="3" stroke-linecap="round"/>
              </svg>
              <div class="ld-h ld-sub"><span>{{ section.settings.metric2_label | default: 'Trafic mensuel' }}</span><b>{{ section.settings.metric2_value | default: '4M' }} <em>+18%</em></b></div>
              <div class="ld-spark"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
            </div>
          </div>
          <div class="ld-side">
            <div class="ld-card">
              <div class="ld-s-title">Score social</div>
              <div class="ld-s-row"><span class="ld-s-ic ig">◐</span><span>Instagram</span><b>499k</b></div>
              <div class="ld-s-row"><span class="ld-s-ic fb">f</span><span>Facebook</span><b>1.3M</b></div>
              <div class="ld-s-row"><span class="ld-s-ic ts">★</span><span>Trustscore</span><b class="pos">4.7</b></div>
            </div>
            <div class="ld-card">
              <div class="ld-s-title">Top produits <b class="ld-pill">253</b></div>
              <div class="ld-prods">
                <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
          </div>
        </div>
        <div class="ld-toast"><i></i> {{ section.settings.toast | default: 'Nouvelle marque détectée' }}</div>
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .ld-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:60px;align-items:center}
  .ld-intro h2{font-size:23px;line-height:1.16;margin:13px 0 16px}
  .ld-stage{position:relative;perspective:1600px}
  .ld-app{position:relative;border-radius:18px;overflow:hidden;border:1px solid var(--border2);
    background:var(--panel);box-shadow:0 40px 90px -40px rgba(0,0,0,.7),0 18px 50px -30px rgba(129,140,248,.4);
    transform:rotateY(-7deg) rotateX(3deg);transform-style:preserve-3d;animation:ld-float 9s ease-in-out infinite}
  @keyframes ld-float{0%,100%{transform:rotateY(-7deg) rotateX(3deg) translateY(0)}50%{transform:rotateY(-5deg) rotateX(2deg) translateY(-10px)}}
  .ld-chrome{display:flex;align-items:center;gap:7px;padding:12px 14px;border-bottom:1px solid var(--border)}
  .ld-dot{width:9px;height:9px;border-radius:50%;flex:0 0 auto}
  .ld-dot.r{background:#ff6b6b}.ld-dot.y{background:#ffd166}.ld-dot.g{background:#36d399}
  .ld-url{margin-left:auto;margin-right:auto;font:11px/1 ui-monospace,monospace;color:var(--muted);
    background:var(--on-glass);border:1px solid var(--on-glass-b);padding:5px 14px;border-radius:7px}
  .ld-body{display:grid;grid-template-columns:36px 1fr .9fr;gap:14px;padding:16px}
  .ld-rail{display:flex;flex-direction:column;gap:10px;align-items:center;padding-top:6px}
  .ld-rail span{width:24px;height:24px;border-radius:8px;background:var(--on-glass);border:1px solid var(--border)}
  .ld-rail span.on{background:var(--cg);border:0;box-shadow:inset 0 1px 1px rgba(255,255,255,.6)}
  .ld-card{background:var(--on-glass);border:1px solid var(--border);border-radius:14px;padding:14px 15px;margin-bottom:14px}
  .ld-side .ld-card:last-child{margin-bottom:0}
  .ld-h{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--muted)}
  .ld-h b{font-size:20px;font-weight:700;letter-spacing:-.03em;color:var(--text)}
  .ld-live{display:inline-flex;align-items:center;gap:7px}
  .ld-live i{width:8px;height:8px;border-radius:50%;background:#36d399;box-shadow:0 0 0 0 rgba(54,211,153,.6);animation:ld-pulse 1.8s ease-out infinite}
  @keyframes ld-pulse{0%{box-shadow:0 0 0 0 rgba(54,211,153,.55)}70%{box-shadow:0 0 0 9px rgba(54,211,153,0)}100%{box-shadow:0 0 0 0 rgba(54,211,153,0)}}
  .ld-chart{width:100%;height:120px;display:block;margin:8px 0 4px}
  .ld-stroke{stroke-dasharray:1400;stroke-dashoffset:1400;animation:ld-draw 2.4s cubic-bezier(.4,0,.2,1) .2s forwards}
  .ld-area{opacity:0;animation:ld-fade 1.2s ease 1.4s forwards}
  @keyframes ld-draw{to{stroke-dashoffset:0}}
  @keyframes ld-fade{to{opacity:1}}
  .ld-sub{margin-top:6px}.ld-sub b{font-size:15px}.ld-sub em{font-style:normal;font-size:11px;color:#36d399;font-weight:600}
  .ld-spark{display:flex;align-items:flex-end;gap:5px;height:34px;margin-top:10px}
  .ld-spark span{flex:1;border-radius:4px 4px 0 0;background:var(--cg);opacity:.85;transform-origin:bottom;animation:ld-bar 2.6s ease-in-out infinite}
  .ld-spark span:nth-child(odd){opacity:.55}
  .ld-spark span:nth-child(1){height:40%;animation-delay:0s}.ld-spark span:nth-child(2){height:65%;animation-delay:.1s}
  .ld-spark span:nth-child(3){height:50%;animation-delay:.2s}.ld-spark span:nth-child(4){height:80%;animation-delay:.3s}
  .ld-spark span:nth-child(5){height:60%;animation-delay:.4s}.ld-spark span:nth-child(6){height:90%;animation-delay:.5s}
  .ld-spark span:nth-child(7){height:55%;animation-delay:.6s}.ld-spark span:nth-child(8){height:75%;animation-delay:.7s}
  .ld-spark span:nth-child(9){height:45%;animation-delay:.8s}.ld-spark span:nth-child(10){height:85%;animation-delay:.9s}
  .ld-spark span:nth-child(11){height:62%;animation-delay:1s}.ld-spark span:nth-child(12){height:70%;animation-delay:1.1s}
  @keyframes ld-bar{0%,100%{transform:scaleY(.82)}50%{transform:scaleY(1)}}
  .ld-s-title{font-size:12px;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
  .ld-pill{font-size:11px;color:#1a1430;background:var(--cg);padding:2px 9px;border-radius:999px;font-weight:700}
  .ld-s-row{display:flex;align-items:center;gap:10px;font-size:12.5px;color:var(--soft);padding:7px 0}
  .ld-s-row b{margin-left:auto;color:var(--text);font-weight:700}
  .ld-s-row b.pos{color:#36d399}
  .ld-s-ic{width:24px;height:24px;border-radius:7px;display:grid;place-items:center;font-size:12px;font-weight:700;color:#fff;flex:0 0 auto}
  .ld-s-ic.ig{background:linear-gradient(45deg,#f09433,#dc2743,#bc1888)}.ld-s-ic.fb{background:#1877f2}
  .ld-s-ic.ts{background:#00b67a}
  .ld-prods{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
  .ld-prods span{aspect-ratio:1;border-radius:9px;background:var(--cg);opacity:.5;animation:ld-tile 3s ease-in-out infinite}
  .ld-prods span:nth-child(2n){opacity:.8}.ld-prods span:nth-child(3n){opacity:.35}
  .ld-prods span:nth-child(1){animation-delay:0s}.ld-prods span:nth-child(2){animation-delay:.2s}.ld-prods span:nth-child(3){animation-delay:.4s}.ld-prods span:nth-child(4){animation-delay:.6s}
  .ld-prods span:nth-child(5){animation-delay:.8s}.ld-prods span:nth-child(6){animation-delay:1s}.ld-prods span:nth-child(7){animation-delay:1.2s}.ld-prods span:nth-child(8){animation-delay:1.4s}
  @keyframes ld-tile{0%,100%{opacity:.4}50%{opacity:.9}}
  .ld-toast{position:absolute;left:18px;bottom:18px;display:inline-flex;align-items:center;gap:9px;
    font-size:12.5px;font-weight:600;color:var(--text);background:rgba(16,16,24,.9);border:1px solid var(--border2);
    padding:10px 15px;border-radius:12px;backdrop-filter:blur(8px);box-shadow:0 20px 40px -20px rgba(0,0,0,.7);
    animation:ld-toast 6s ease-in-out infinite}
  .theme-light .ld-toast{background:rgba(255,255,255,.92)}
  .ld-toast i{width:18px;height:18px;border-radius:50%;background:var(--cg);display:inline-block;flex:0 0 auto;
    box-shadow:inset 0 1px 1px rgba(255,255,255,.6)}
  @keyframes ld-toast{0%,18%{opacity:0;transform:translateY(14px) scale(.96)}28%,66%{opacity:1;transform:translateY(0) scale(1)}78%,100%{opacity:0;transform:translateY(14px) scale(.96)}}
  @media (max-width:980px){.ld-grid{grid-template-columns:1fr;gap:40px}.ld-app{transform:none;animation:none}.ld-body{grid-template-columns:1fr}.ld-rail{display:none}.ld-side{display:grid;grid-template-columns:1fr 1fr;gap:14px}.ld-side .ld-card{margin-bottom:0}}
  @media (prefers-reduced-motion:reduce){.ld-app,.ld-stroke,.ld-area,.ld-spark span,.ld-prods span,.ld-toast,.ld-live i{animation:none}.ld-stroke{stroke-dashoffset:0}.ld-area{opacity:1}}
{%- endstyle -%}

{% schema %}
{
  "name": "360labs · Dashboard",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "dark" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La Plateforme · Bientôt" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Toute votre marque, pilotée en direct." },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Vos données réunies et lisibles : publicités, social, trafic, produits — et un copilote qui vous dit quoi faire chaque jour." },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Rejoindre la liste d'attente" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-glass", "label": "Iridescent" }, { "value": "btn-soft", "label": "Discret" } ], "default": "btn-glass" },
    { "type": "header", "content": "Mockup (valeurs affichées)" },
    { "type": "text", "id": "domain", "label": "Domaine (barre)", "default": "360labs.app" },
    { "type": "text", "id": "metric_label", "label": "Métrique 1 — libellé", "default": "Publicités live" },
    { "type": "text", "id": "metric_value", "label": "Métrique 1 — valeur", "default": "6 559" },
    { "type": "text", "id": "metric2_label", "label": "Métrique 2 — libellé", "default": "Trafic mensuel" },
    { "type": "text", "id": "metric2_value", "label": "Métrique 2 — valeur", "default": "4M" },
    { "type": "text", "id": "toast", "label": "Texte du toast", "default": "Nouvelle marque détectée" }
  ],
  "presets": [ { "name": "360labs · Dashboard" } ]
}
{% endschema %}
