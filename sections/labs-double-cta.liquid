{%- comment -%} 360labs — Double CTA (portes) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Double CTA' }}">
  <div class="wrap">
    <div class="final-head reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    </div>
    <div class="doors reveal">
      {%- for block in section.blocks -%}
        <div class="door" {% if block.settings.anchor != blank %}id="{{ block.settings.anchor }}"{% endif %} {{ block.shopify_attributes }}>
          {%- if block.settings.eyebrow != blank -%}<div class="eyebrow">{{ block.settings.eyebrow }}</div>{%- endif -%}
          {%- if block.settings.title != blank -%}<h3>{{ block.settings.title }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
          {%- if block.settings.cta_label != blank -%}<a class="btn {{ block.settings.cta_style }}" href="{{ block.settings.cta_url | default: '#' }}">{{ block.settings.cta_label }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "360labs · Double CTA",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "contact" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Et maintenant" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "À vous de jouer." },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "Vous savez qui nous sommes et comment on travaille. La vraie question : vous passez à l'action, ou vous laissez vos concurrents prendre de l'avance ?" }
  ],
  "blocks": [
    {
      "type": "door",
      "name": "Porte (CTA)",
      "settings": [
        { "type": "text", "id": "anchor", "label": "Ancre (id)" },
        { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Marque e-commerce" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Faites auditer votre marque." },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Un audit CRO & Pub gratuit, sans engagement." },
        { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Réserver mon audit gratuit" },
        { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
        { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-glass", "label": "Iridescent" }, { "value": "btn-soft", "label": "Discret" } ], "default": "btn-glass" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Double CTA",
      "blocks": [
        { "type": "door", "settings": { "eyebrow": "Marque e-commerce", "title": "Faites auditer votre marque.", "text": "Un audit CRO & Pub gratuit, sans engagement. On analyse, on vous dit où sont vos leviers.", "cta_label": "Réserver mon audit gratuit", "cta_style": "btn-glass" } },
        { "type": "door", "settings": { "anchor": "entreprises", "eyebrow": "Entreprise · B2B", "title": "Construisons votre présence digitale.", "text": "Site, visibilité, image de marque, automatisation : le groupe au service des entreprises.", "cta_label": "Parler à un expert", "cta_style": "btn-soft" } }
      ]
    }
  ]
}
{% endschema %}
