{%- comment -%} 360labs — Bibliothèque de ressources (cartes filtrables) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Ressources' }}" data-resources>
  <div class="wrap">
    <div class="head reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
    </div>

    {%- if section.settings.show_filters and section.blocks.size > 1 -%}
      {%- assign cats = '' -%}
      {%- for block in section.blocks -%}{%- if block.settings.tag != blank -%}{%- assign cats = cats | append: block.settings.tag | strip | append: '~' -%}{%- endif -%}{%- endfor -%}
      {%- assign catlist = cats | split: '~' | uniq -%}
      <div class="res-filters reveal">
        <button type="button" class="res-fil on" data-filter="*">{{ section.settings.all_label | default: 'Tout' }}</button>
        {%- for c in catlist -%}{%- if c != blank -%}<button type="button" class="res-fil" data-filter="{{ c | downcase }}">{{ c }}</button>{%- endif -%}{%- endfor -%}
      </div>
    {%- endif -%}

    <div class="res-grid reveal">
      {%- for block in section.blocks -%}
        <a class="rcard{% if block.settings.image != blank %} has-thumb{% endif %}" data-cat="{{ block.settings.tag | downcase | strip }}" href="{{ block.settings.url | default: '#' }}"{% if block.settings.url contains '://' %} target="_blank" rel="noopener"{% endif %} {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <span class="rc-thumb">{{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 600', alt: block.settings.title }}</span>
          {%- endif -%}
          <span class="rc-top">
            {%- if block.settings.tag != blank -%}<span class="rc-tag">{{ block.settings.tag }}</span>{%- endif -%}
            {%- if block.settings.format != blank -%}<span class="rc-fmt">{{ block.settings.format }}</span>{%- endif -%}
          </span>
          {%- unless block.settings.image != blank -%}
            <span class="rc-ic">
              {%- case block.settings.icon -%}
                {%- when 'video' -%}<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="13" rx="2"></rect><path d="M10 9l4 2.5-4 2.5z"></path></svg>
                {%- when 'download' -%}<svg viewBox="0 0 24 24"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"></path></svg>
                {%- when 'template' -%}<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"></path></svg>
                {%- when 'checklist' -%}<svg viewBox="0 0 24 24"><path d="M9 11l2 2 4-4M4 6h2M4 12h2M4 18h2M9 6h11M9 18h11"></path></svg>
                {%- when 'link' -%}<svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1"></path></svg>
                {%- else -%}<svg viewBox="0 0 24 24"><path d="M4 5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"></path><path d="M13 3v5h5"></path></svg>
              {%- endcase -%}
            </span>
          {%- endunless -%}
          <h3>{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
          <div class="rc-meta">{{ block.settings.meta | default: 'Découvrir' }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></div>
        </a>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_filters -%}
    <script>
      (function () {
        var root = document.currentScript.closest('[data-resources]');
        if (!root) return;
        var fils = root.querySelectorAll('.res-fil');
        var cards = root.querySelectorAll('.rcard');
        root.addEventListener('click', function (e) {
          var b = e.target.closest('.res-fil');
          if (!b) return;
          fils.forEach(function (f) { f.classList.toggle('on', f === b); });
          var f = b.getAttribute('data-filter');
          cards.forEach(function (c) {
            var show = (f === '*' || c.getAttribute('data-cat') === f);
            c.classList.toggle('is-hidden', !show);
          });
        });
      })();
    </script>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "360labs · Ressources",
  "tag": "section",
  "class": "labs-shopify-section",
  "max_blocks": 30,
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Ressources" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Guides, templates & assets à télécharger." },
    { "type": "textarea", "id": "lede", "label": "Accroche", "default": "Des ressources concrètes pour faire grandir votre marque e-commerce." },
    { "type": "header", "content": "Filtres" },
    { "type": "checkbox", "id": "show_filters", "label": "Afficher les filtres par catégorie", "default": true },
    { "type": "text", "id": "all_label", "label": "Libellé « tout »", "default": "Tout" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Ressource",
      "settings": [
        { "type": "text", "id": "tag", "label": "Catégorie (sert aussi aux filtres)", "default": "Guide" },
        { "type": "text", "id": "format", "label": "Format (badge : PDF, Notion, Vidéo…)" },
        { "type": "select", "id": "icon", "label": "Icône", "options": [ {"value":"file","label":"Guide / document"}, {"value":"template","label":"Template"}, {"value":"checklist","label":"Checklist"}, {"value":"video","label":"Vidéo"}, {"value":"download","label":"Téléchargement"}, {"value":"link","label":"Lien externe"} ], "default": "file" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Le guide du TikTok Shop" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Tout pour lancer et scaler une marque sur TikTok Shop." },
        { "type": "text", "id": "meta", "label": "Libellé du lien", "default": "Télécharger" },
        { "type": "url", "id": "url", "label": "Lien (fichier, page ou URL externe)" },
        { "type": "image_picker", "id": "image", "label": "Miniature (optionnel — remplace l'icône)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Ressources",
      "settings": { "show_filters": true },
      "blocks": [
        { "type": "resource", "settings": { "tag": "Guide", "format": "PDF", "icon": "file", "title": "Le guide du TikTok Shop", "text": "Tout pour lancer et scaler une marque sur TikTok Shop en 2026.", "meta": "Télécharger" } },
        { "type": "resource", "settings": { "tag": "Template", "format": "Notion", "icon": "template", "title": "Template d'audit CRO", "text": "La checklist qu'on utilise pour auditer un site e-commerce.", "meta": "Obtenir le template" } },
        { "type": "resource", "settings": { "tag": "Checklist", "format": "PDF", "icon": "checklist", "title": "Checklist de lancement de marque", "text": "Les 40 points à valider avant d'ouvrir votre boutique.", "meta": "Télécharger" } },
        { "type": "resource", "settings": { "tag": "Asset", "format": "ZIP", "icon": "download", "title": "Pack créatif UGC", "text": "Nos modèles de scripts et briefs pour vos créateurs.", "meta": "Télécharger" } },
        { "type": "resource", "settings": { "tag": "Vidéo", "format": "Vidéo", "icon": "video", "title": "Créer une fiche produit qui convertit", "text": "Pas-à-pas vidéo pour structurer une page produit.", "meta": "Regarder" } },
        { "type": "resource", "settings": { "tag": "Template", "format": "Google Sheets", "icon": "template", "title": "Plan d'acquisition 90 jours", "text": "Le cadre pour structurer vos premières campagnes.", "meta": "Obtenir le template" } }
      ]
    }
  ]
}
{% endschema %}
