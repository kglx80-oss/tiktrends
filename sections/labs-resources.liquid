{%- comment -%} 360labs — Grille de ressources / tutoriels (rcards) {%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Ressources' }}">
  <div class="wrap">
    <div class="head reveal">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
    </div>
    <div class="res-grid reveal">
      {%- for block in section.blocks -%}
        <a class="rcard" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.tag != blank -%}<span class="rc-tag">{{ block.settings.tag }}</span>{%- endif -%}
          <span class="rc-ic">
            {%- case block.settings.icon -%}
              {%- when 'video' -%}<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="13" rx="2"></rect><path d="M10 9l4 2.5-4 2.5z"></path></svg>
              {%- when 'download' -%}<svg viewBox="0 0 24 24"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"></path></svg>
              {%- when 'template' -%}<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"></path></svg>
              {%- else -%}<svg viewBox="0 0 24 24"><path d="M4 5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"></path><path d="M13 3v5h5"></path></svg>
            {%- endcase -%}
          </span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
          <div class="rc-meta">{{ block.settings.meta | default: 'Découvrir' }} <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "360labs · Ressources",
  "tag": "section",
  "class": "labs-shopify-section",
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Ressources" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Guides, templates & assets à télécharger." },
    { "type": "textarea", "id": "lede", "label": "Accroche", "default": "Des ressources concrètes pour faire grandir votre marque e-commerce." }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Ressource",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [ {"value":"file","label":"Guide"}, {"value":"video","label":"Vidéo"}, {"value":"download","label":"Téléchargement"}, {"value":"template","label":"Template"} ], "default": "file" },
        { "type": "text", "id": "tag", "label": "Étiquette", "default": "Guide" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Le guide du TikTok Shop" },
        { "type": "textarea", "id": "text", "label": "Texte", "default": "Tout pour lancer et scaler une marque sur TikTok Shop." },
        { "type": "text", "id": "meta", "label": "Libellé du lien", "default": "Télécharger" },
        { "type": "url", "id": "url", "label": "Lien" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Ressources",
      "blocks": [
        { "type": "resource", "settings": { "icon": "file", "tag": "Guide", "title": "Le guide du TikTok Shop", "text": "Tout pour lancer et scaler une marque sur TikTok Shop en 2026.", "meta": "Télécharger" } },
        { "type": "resource", "settings": { "icon": "template", "tag": "Template", "title": "Template d'audit CRO", "text": "La checklist qu'on utilise pour auditer un site e-commerce.", "meta": "Obtenir le template" } },
        { "type": "resource", "settings": { "icon": "download", "tag": "Asset", "title": "Pack créatif UGC", "text": "Nos modèles de scripts et briefs pour vos créateurs.", "meta": "Télécharger" } },
        { "type": "resource", "settings": { "icon": "video", "tag": "Tutoriel", "title": "Créer une fiche produit qui convertit", "text": "Pas-à-pas vidéo pour structurer une page produit.", "meta": "Regarder" } },
        { "type": "resource", "settings": { "icon": "file", "tag": "Guide", "title": "Emailing & CRM e-commerce", "text": "Les séquences qui récupèrent du chiffre d'affaires.", "meta": "Lire le guide" } },
        { "type": "resource", "settings": { "icon": "template", "tag": "Template", "title": "Plan d'acquisition 90 jours", "text": "Le cadre pour structurer vos premières campagnes.", "meta": "Obtenir le template" } }
      ]
    }
  ]
}
{% endschema %}
