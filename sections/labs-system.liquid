{%- comment -%}
  360labs — Split "Système de croissance" : texte + mockup produit animé (leviers en cascade)
  Visuel portrait raccord avec le dashboard : leviers reliés par un flux, activation en boucle, nœud résultat.
{%- endcomment -%}
<section class="labs theme-{{ section.settings.theme }} pad labs-section" {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %} data-screen-label="{{ section.settings.label | default: 'Système' }}">
  <div class="wrap split reveal" style="{% if section.settings.media_position == 'left' %}direction:rtl{% endif %}">
    <div class="split-txt" style="direction:ltr">
      {%- if section.settings.eyebrow != blank -%}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- endif -%}
      {%- if section.settings.cta_label != blank -%}<a class="btn {{ section.settings.cta_style }}" href="{{ section.settings.cta_url | default: '#' }}">{{ section.settings.cta_label }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>{%- endif -%}
    </div>

    <div class="lsys-stage" style="direction:ltr">
      <div class="lsys" aria-hidden="true">
        <div class="lsys-top"><span class="lsys-live"></span>{{ section.settings.panel_title | default: 'Système de croissance' }}</div>
        <div class="lsys-rows" style="--n:{{ section.blocks.size }}">
          {%- for block in section.blocks -%}
            <div class="lsys-row" style="--i:{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <span class="lsys-ic">
                {%- case block.settings.icon -%}
                  {%- when 'globe' -%}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"/></svg>
                  {%- when 'chart' -%}<svg viewBox="0 0 24 24"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/></svg>
                  {%- when 'video' -%}<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="13" rx="2"/><path d="M10 9l4 2.5-4 2.5z"/></svg>
                  {%- when 'mail' -%}<svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="3"/><path d="M9 9h6M9 13h6"/></svg>
                {%- endcase -%}
              </span>
              <div class="lsys-meta"><b>{{ block.settings.title }}</b><span class="lsys-bar"><i></i></span></div>
              <span class="lsys-chk"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
            </div>
          {%- endfor -%}
        </div>
        <div class="lsys-result">
          <div><span class="lsys-r-lbl">{{ section.settings.result_label | default: 'Résultat : système complet' }}</span><b class="grad-on">{{ section.settings.result_value | default: '+850%' }}</b></div>
          <span class="lsys-r-tag">{{ section.settings.result_tag | default: 'de croissance' }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .lsys-stage{position:relative}
  .lsys{position:relative;background:var(--panel);border:1px solid var(--border2);border-radius:var(--r-xl);
    padding:24px 22px;box-shadow:0 40px 90px -44px rgba(0,0,0,.7),0 18px 50px -30px rgba(129,140,248,.35);
    animation:lsys-float 9s ease-in-out infinite}
  @keyframes lsys-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
  .lsys-top{display:flex;align-items:center;gap:9px;font-size:12.5px;font-weight:600;letter-spacing:-.01em;
    color:var(--soft);padding-bottom:16px;border-bottom:1px solid var(--border);margin-bottom:8px}
  .lsys-live{width:9px;height:9px;border-radius:50%;background:#36d399;box-shadow:0 0 0 0 rgba(54,211,153,.6);animation:lsys-pulse 1.8s ease-out infinite}
  @keyframes lsys-pulse{0%{box-shadow:0 0 0 0 rgba(54,211,153,.55)}70%{box-shadow:0 0 0 8px rgba(54,211,153,0)}100%{box-shadow:0 0 0 0 rgba(54,211,153,0)}}
  .lsys-rows{position:relative;padding:6px 0}
  .lsys-rows::before{content:"";position:absolute;left:30px;top:10px;bottom:10px;width:2px;border-radius:2px;
    background:linear-gradient(var(--peri),var(--rose),var(--sable));background-size:100% 200%;
    opacity:.5;animation:lsys-flow 3s linear infinite;
    -webkit-mask:linear-gradient(180deg,transparent,#000 16%,#000 84%,transparent);
    mask:linear-gradient(180deg,transparent,#000 16%,#000 84%,transparent)}
  @keyframes lsys-flow{to{background-position:0 -200%}}
  .lsys-row{position:relative;display:flex;align-items:center;gap:14px;padding:12px 10px;border-radius:13px;
    border:1px solid transparent;transition:background .3s,border-color .3s;
    animation:lsys-active calc(var(--n,4) * 1.4s) ease-in-out infinite;animation-delay:calc(var(--i) * 1.4s)}
  @keyframes lsys-active{0%,12%{background:var(--on-glass);border-color:var(--border2)}30%,100%{background:transparent;border-color:transparent}}
  .lsys-ic{position:relative;z-index:1;width:40px;height:40px;flex:0 0 auto;border-radius:12px;display:grid;place-items:center;
    background:color-mix(in oklab,var(--accent-ink) 16%,var(--panel));border:1px solid color-mix(in oklab,var(--accent-ink) 32%,transparent)}
  .lsys-ic svg{width:20px;height:20px;stroke:var(--accent-ink);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .lsys-row .lsys-meta{flex:1;min-width:0}
  .lsys-meta b{display:block;font-size:14.5px;font-weight:600;letter-spacing:-.01em;color:var(--text);margin-bottom:7px}
  .lsys-bar{display:block;height:6px;border-radius:6px;background:var(--on-glass);border:1px solid var(--border);overflow:hidden}
  .lsys-bar i{display:block;height:100%;width:30%;border-radius:6px;background:var(--cg);
    animation:lsys-fill calc(var(--n,4) * 1.4s) ease-in-out infinite;animation-delay:calc(var(--i) * 1.4s)}
  @keyframes lsys-fill{0%{width:18%}26%{width:100%}100%{width:100%}}
  .lsys-chk{flex:0 0 auto;width:24px;height:24px;border-radius:50%;display:grid;place-items:center;
    background:var(--cg);opacity:0;transform:scale(.5);
    animation:lsys-chk calc(var(--n,4) * 1.4s) ease-in-out infinite;animation-delay:calc(var(--i) * 1.4s)}
  .lsys-chk svg{width:13px;height:13px;stroke:#1a1430;fill:none;stroke-width:2.6;stroke-linecap:round;stroke-linejoin:round}
  @keyframes lsys-chk{0%,18%{opacity:0;transform:scale(.5)}30%,100%{opacity:1;transform:scale(1)}}
  .lsys-result{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:10px;
    padding:18px;border-radius:15px;background:var(--cg);box-shadow:inset 0 1.5px 1px rgba(255,255,255,.5)}
  .lsys-result .lsys-r-lbl{display:block;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(26,20,48,.62)}
  .lsys-result b{font-size:30px;font-weight:800;letter-spacing:-.04em;line-height:1.05;color:#1a1430}
  .lsys-result .grad-on{-webkit-text-fill-color:#1a1430}
  .lsys-r-tag{font-size:12.5px;font-weight:600;color:rgba(26,20,48,.7)}
  @media (max-width:620px){
    .lsys{padding:18px 16px}
    .lsys-row{gap:11px;padding:10px 6px}
    .lsys-ic{width:36px;height:36px}
    .lsys-rows::before{left:24px}
    .lsys-result{padding:15px}
    .lsys-result b{font-size:25px}
  }
  @media (prefers-reduced-motion:reduce){.lsys,.lsys-live,.lsys-rows::before,.lsys-row,.lsys-bar i,.lsys-chk{animation:none}.lsys-chk{opacity:1;transform:none}.lsys-bar i{width:100%}}
{%- endstyle -%}

{% schema %}
{
  "name": "360labs · Système",
  "tag": "section",
  "class": "labs-shopify-section",
  "max_blocks": 6,
  "settings": [
    { "type": "select", "id": "theme", "label": "Thème", "options": [ { "value": "dark", "label": "Sombre" }, { "value": "light", "label": "Clair" } ], "default": "light" },
    { "type": "text", "id": "anchor", "label": "Ancre (id)" },
    { "type": "text", "id": "label", "label": "Libellé éditeur" },
    { "type": "select", "id": "media_position", "label": "Position du mockup", "options": [ { "value": "right", "label": "Droite" }, { "value": "left", "label": "Gauche" } ], "default": "right" },
    { "type": "header", "content": "Texte" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La thèse" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Trop de marques meurent d'un seul levier manquant." },
    { "type": "richtext", "id": "text", "label": "Paragraphes", "default": "<p>Un beau site sans trafic. Du trafic qui ne convertit pas. La plupart des marques ne manquent pas d'ambition : elles manquent d'un <strong>système complet</strong>.</p><p>Depuis 2019, on a construit l'inverse d'une agence mono-levier : un groupe qui couvre <strong>toute la chaîne</strong>.</p>" },
    { "type": "text", "id": "cta_label", "label": "Bouton", "default": "Comprendre le Groupe" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "select", "id": "cta_style", "label": "Style du bouton", "options": [ { "value": "btn-soft", "label": "Discret" }, { "value": "btn-glass", "label": "Iridescent" } ], "default": "btn-soft" },
    { "type": "header", "content": "Mockup — résultat" },
    { "type": "text", "id": "panel_title", "label": "Titre du panneau", "default": "Système de croissance" },
    { "type": "text", "id": "result_label", "label": "Résultat — libellé", "default": "Résultat : système complet" },
    { "type": "text", "id": "result_value", "label": "Résultat — valeur", "default": "+850%" },
    { "type": "text", "id": "result_tag", "label": "Résultat — mention", "default": "de croissance" }
  ],
  "blocks": [
    {
      "type": "lever",
      "name": "Levier",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "options": [ {"value":"globe","label":"Site / Web"}, {"value":"chart","label":"Acquisition"}, {"value":"video","label":"Studio / contenu"}, {"value":"mail","label":"CRM / e-mail"}, {"value":"box","label":"Générique"} ], "default": "globe" },
        { "type": "text", "id": "title", "label": "Titre du levier", "default": "Site & conversion" }
      ]
    }
  ],
  "presets": [
    {
      "name": "360labs · Système",
      "blocks": [
        { "type": "lever", "settings": { "icon": "globe", "title": "Site & conversion" } },
        { "type": "lever", "settings": { "icon": "chart", "title": "Acquisition rentable" } },
        { "type": "lever", "settings": { "icon": "video", "title": "Studio & contenu" } },
        { "type": "lever", "settings": { "icon": "mail", "title": "CRM & rétention" } }
      ]
    }
  ]
}
{% endschema %}
